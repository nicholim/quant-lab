# Copy this file to `.env` and fill in your key. `.env` is gitignored.
# Loaded automatically at import (python-dotenv). A real exported env var,
# if set, always overrides what's here.

# Free Finnhub API key (https://finnhub.io) — used for real-time SPOT quotes
# only. Option chains are keyless via yfinance. Optional: if unset, spot
# quotes fall back to yfinance.
FINNHUB_API_KEY=

# Set to 1 to force the offline demo (serves the bundled sample chain instead
# of hitting the network). Leave unset/0 for live data.
# OPTIONS_PRICING_OFFLINE=0
