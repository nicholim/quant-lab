REDIS_URL=redis://localhost:6379
# Storage sink: "timescale" (default; needs an external TimescaleDB) or
# "duckdb" (local file, no external DB or network — runnable anywhere).
STORAGE_BACKEND=timescale
DATABASE_URL=postgresql://user:password@localhost:5432/marketdata
# Used only when STORAGE_BACKEND=duckdb.
DUCKDB_PATH=data/marketdata.duckdb
# Exchange adapter (keyless public trade feeds). One of:
#   binance  (default; URL-embedded @trade streams; symbols like btcusdt)
#   coinbase (Coinbase Exchange matches feed; symbols like btcusd)
#   kraken   (Kraken v1 trade feed; symbols like btcusd -> XBT/USD)
#   bitstamp (Bitstamp live_trades channel; symbols like btcusd)
# Overridable per-run with `python main.py --exchange <name>`.
EXCHANGE=binance
WS_URL=wss://stream.binance.com:9443/ws
SYMBOLS=btcusdt,ethusdt,solusdt
LOG_LEVEL=INFO
BATCH_SIZE=100
FLUSH_INTERVAL_SECONDS=5
# Backpressure cap on the in-memory trade buffer (blocks-then-drops-oldest when full).
MAX_BUFFER_SIZE=1000
